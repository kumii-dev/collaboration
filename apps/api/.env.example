# ==============================================
# BACKEND API ENVIRONMENT VARIABLES
# ==============================================

# Server
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001

# Supabase
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Supabase Storage
SUPABASE_STORAGE_BUCKET=collaboration-attachments

# JWT Secret (for additional token validation if needed)
JWT_SECRET=your_jwt_secret_key_change_in_production

# Token exchange secret — used to derive deterministic passwords for Lovable users.
# Set to any random 32+ character string. Must match across deployments.
EXCHANGE_SECRET=your_exchange_secret_change_in_production

# Resend (Email)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@kumii.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:5173
# Production URL of the web app — used in email links and moderation notifications.
# Set this in your Vercel environment variables to the canonical domain.
APP_URL=https://communities-ten.vercel.app

# Logging
LOG_LEVEL=debug

# Security
SESSION_SECRET=your_session_secret_change_in_production
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf
MAX_FILE_SIZE_MB=10

# Admin bootstrap — comma-separated list of emails to auto-promote to 'admin' on every login.
# These users will be granted admin role automatically during /exchange and /refresh.
# ADMIN_EMAILS=you@example.com,another@example.com
